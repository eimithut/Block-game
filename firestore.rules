rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && userId.matches('^' + request.auth.uid + '(_.*)?$');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidPlayer(data) {
      return hasOnlyAllowedFields(['id', 'name', 'x', 'y', 'z', 'skinColor', 'yaw', 'pitch', 'skinUrl']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.x is number && data.y is number && data.z is number &&
             (!('yaw' in data) || data.yaw is number) &&
             (!('pitch' in data) || data.pitch is number) &&
             (!('skinUrl' in data) || (data.skinUrl is string && data.skinUrl.size() < 1000000)) &&
             data.skinColor is string && data.skinColor.size() == 7;
    }

    function isValidBlock(data) {
      return hasOnlyAllowedFields(['x', 'y', 'z', 'type']) &&
             data.x is number && data.y is number && data.z is number &&
             data.type is number;
    }

    function isValidRoom(data) {
      return hasOnlyAllowedFields(['roomId', 'name', 'hostId', 'hostName', 'isLocked', 'password', 'playerCount', 'createdAt', 'lastActive']) &&
             data.roomId is string && data.roomId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.hostId is string &&
             data.isLocked is bool &&
             (!('password' in data) || data.password is string) &&
             (!('playerCount' in data) || data.playerCount is number) &&
             data.createdAt is string;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.hostId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerCount', 'lastActive']));
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;
    }

    match /rooms/{roomId}/players/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPlayer(request.resource.data);
      allow update: if isOwner(userId) && isValidPlayer(request.resource.data);
      allow delete: if isOwner(userId);
    }
    
    match /rooms/{roomId}/blocks/{blockId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidBlock(request.resource.data);
    }
  }
}
